# ============================================
# Star Agents Orchestrator - Environment Variables
# ============================================

# ===================
# REQUIRED
# ===================

# Database (Supabase Session Pooler)
DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Security
API_KEY=your-api-key-here

# Qdrant (RAG)
QDRANT_URL=http://localhost:6333

# RabbitMQ - Message broker para processamento assíncrono (follow-ups, etc)
# Em Docker Compose/Swarm usar: amqp://rabbitmq:5672/
RABBIT_URL=amqp://localhost:5672/
RABBIT_USER=guest
RABBIT_PASS=guest
RABBIT_FOLLOW_UP_QUEUE=follow_ups

# ===================
# OPTIONAL (defaults in config.py)
# ===================

# Redis - default: redis://localhost:6379
# Em Docker Compose/Swarm usar: redis://redis:6379
# REDIS_URL=redis://redis:6379

# Database echo SQL queries - default: false
# DB_ECHO=false

# Debug mode - default: false
# DEBUG=false

# Dev mode - bypassa buffer e outras features para dev local - default: false
# DEV_MODE=false

# Message buffer delay in seconds - default: 5
# Time to wait for additional messages before processing (Chatwoot)
# MESSAGE_BUFFER_DELAY=5

# Max messages in chat history - default: 10
# MAX_CHAT_HISTORY_MESSAGES=10
